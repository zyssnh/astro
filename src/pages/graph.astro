---
import BaseLayout from "../layouts/BaseLayout.astro";
import "../styles/sci-fi.css";
import { buildGraph } from "../utils/graph";

const allPosts = Object.values(import.meta.glob("./posts/**/*.md", { eager: true }));
const { nodes, links } = buildGraph(allPosts);

const cP: Record<string, { desc: string }> = {};
for (const post of allPosts as any[]) {
    const u: string = post.url || '';
    const s = u.split('/').filter(Boolean).pop() || '';
    cP[s] = { desc: post.frontmatter.description || '' };
}
const gData = JSON.stringify({ nodes, links, contentPreview: cP });
---

<BaseLayout pageTitle="双链">

<div id="uni-root" style="position:fixed;inset:0;z-index:0;background:#020617;"></div>

<div id="star-lbl" style="position:fixed;bottom:5rem;left:50%;transform:translateX(-50%);z-index:10;font:0.85rem monospace;color:#22d3ee;text-shadow:0 0 12px rgba(34,211,238,.5);opacity:0;transition:opacity .3s;pointer-events:none"></div>

<div id="pv-card" style="position:fixed;right:1.5rem;top:5rem;z-index:20;width:280px;max-height:55vh;overflow-y:auto;padding:1.25rem;border-radius:1rem;backdrop-filter:blur(16px);opacity:0;transform:translateX(20px);transition:all .35s;pointer-events:none;border:1px solid">
  <h3 id="pv-t" style="font-size:1rem;font-weight:700;margin:0 0 .35rem"></h3>
  <div id="pv-d" style="font-size:.8rem;line-height:1.5;margin-bottom:.6rem"></div>
  <div id="pv-g" style="display:flex;flex-wrap:wrap;gap:.3rem;margin-bottom:.5rem"></div>
  <div style="display:flex;gap:1rem;font:0.75rem monospace"><span id="pv-o" style="color:#22d3ee"></span><span id="pv-i" style="color:#f472b6"></span></div>
  <a id="pv-go" href="#" style="display:inline-flex;align-items:center;gap:.3rem;margin-top:.75rem;font-size:.8rem;font-weight:600;text-decoration:none">曲速跃迁 →</a>
</div>

<div id="set-pn" style="position:fixed;left:1.5rem;top:5rem;z-index:20;width:240px;padding:1rem;border-radius:1rem;backdrop-filter:blur(16px);border:1px solid;display:none">
  <label style="display:block;margin-bottom:.6rem;font-size:.7rem"><span style="text-transform:uppercase;letter-spacing:.05em">亮度</span><input type="range" id="s-bright" min="0.3" max="2" step="0.1" value="1" style="width:100%;accent-color:#22d3ee"></label>
  <label style="display:block;margin-bottom:.6rem;font-size:.7rem"><span style="text-transform:uppercase;letter-spacing:.05em">密度</span><input type="range" id="s-dense" min="3" max="15" step="0.5" value="8" style="width:100%;accent-color:#22d3ee"></label>
  <label style="display:block;margin-bottom:.6rem;font-size:.7rem"><span style="text-transform:uppercase;letter-spacing:.05em">转速</span><input type="range" id="s-spin" min="0" max="3" step="0.1" value="0.3" style="width:100%;accent-color:#22d3ee"></label>
  <label style="display:block;font-size:.7rem"><span style="text-transform:uppercase;letter-spacing:.05em">星云</span><select id="s-theme" style="width:100%;padding:.25rem .4rem;border-radius:.4rem;font-size:.75rem"><option value="cyan">深空青蓝</option><option value="magenta">玫瑰星云</option><option value="gold">黄金星系</option><option value="nebula">多彩星云</option></select></label>
</div>

<div style="position:fixed;bottom:1.5rem;left:1.5rem;z-index:20;display:flex;gap:.5rem">
  <button id="btn-set" style="padding:.35rem .8rem;border-radius:.4rem;font-size:.75rem;border:1px solid;cursor:pointer;font-family:inherit">⚙ 星图</button>
  <span style="padding:.35rem .8rem;border-radius:.4rem;font-size:.75rem;border:1px solid">{nodes.length} 恒星 · {links.length} 链路</span>
</div>

<div id="graph-data" style="display:none" data-json={gData}></div>

<style>
  html.light #uni-root { background: #f8fafc; }
  html.dark #uni-root { background: #020617; }
  html.light #pv-card { background: rgba(255,255,255,.85); border-color: #e5e7eb; }
  html.dark #pv-card { background: rgba(11,20,37,.88); border-color: rgba(34,211,238,.18); }
  html.light #pv-t { color: #1a1d23; } html.dark #pv-t { color: #e4e8f1; }
  html.light #pv-d { color: #6b7280; } html.dark #pv-d { color: #94a3b8; }
  html.light #pv-go { color: #0891b2; } html.dark #pv-go { color: #22d3ee; }
  html.light #set-pn { background: rgba(255,255,255,.85); border-color: #e5e7eb; }
  html.dark #set-pn { background: rgba(11,20,37,.88); border-color: rgba(34,211,238,.15); }
  html.light #set-pn label span { color: #6b7280; } html.dark #set-pn label span { color: #94a3b8; }
  html.light #set-pn select { background: #f9fafb; color: #374151; border-color: #d1d5db; }
  html.dark #set-pn select { background: rgba(255,255,255,.05); color: #94a3b8; border-color: rgba(255,255,255,.1); }
  html.light #btn-set, html.light #btn-set+span { background: rgba(255,255,255,.75); border-color: #e5e7eb; color: #6b7280; }
  html.dark #btn-set, html.dark #btn-set+span { background: rgba(11,20,37,.75); border-color: rgba(255,255,255,.1); color: #94a3b8; }
</style>

<script>
  import * as THREE from 'three';
  import { OrbitControls } from 'three/examples/jsm/controls/OrbitControls.js';

  (function start() {
    const dEl = document.getElementById('graph-data');
    if (!dEl || !dEl.dataset.json) {
      console.warn('Graph data not found, retrying...');
      setTimeout(start, 100);
      return;
    }
    const data = JSON.parse(dEl.dataset.json);
    const gNodes = data.nodes, gLinks = data.links, cP = data.contentPreview || {};

    const sets = { bright:1, dense:8, spin:.3, theme:'cyan' };
    const pals = {
      cyan:{core:0x22d3ee,nebula:[0x0e2a4a,0x061a2e],fog:0x020617},
      magenta:{core:0xf472b6,nebula:[0x2e0a2a,0x1a0620],fog:0x0d0210},
      gold:{core:0xfbbf24,nebula:[0x2e1f0a,0x1a1206],fog:0x0a0802},
      nebula:{core:0xa78bfa,nebula:[0x1a0a3e,0x0e1a3e],fog:0x050510},
    };
    let pal = pals[sets.theme];

    // Create canvas
    const root = document.getElementById('uni-root');
    const cvs = document.createElement('canvas');
    cvs.id = 'cvs';
    cvs.style.display = 'block';
    cvs.style.width = '100%';
    cvs.style.height = '100%';
    root.appendChild(cvs);

    const renderer = new THREE.WebGLRenderer({canvas:cvs,antialias:true,alpha:false});
    renderer.setPixelRatio(Math.min(window.devicePixelRatio,2));
    renderer.toneMapping=THREE.ACESFilmicToneMapping;
    renderer.toneMappingExposure=1;

    const scene = new THREE.Scene();
    scene.fog=new THREE.FogExp2(pal.fog,6e-5);
    scene.background=new THREE.Color(pal.fog);
    const cam = new THREE.PerspectiveCamera(50,2,.5,200);
    cam.position.set(0,4,24);
    const ctrl = new OrbitControls(cam,renderer.domElement);
    ctrl.enableDamping=true;ctrl.dampingFactor=.06;ctrl.minDistance=5;ctrl.maxDistance=70;
    ctrl.maxPolarAngle=Math.PI*.85;ctrl.autoRotate=true;ctrl.autoRotateSpeed=sets.spin;

    scene.add(new THREE.AmbientLight(0x1a2a5a,.4));
    const coreLt = new THREE.PointLight(pal.core,100,60,1.5); scene.add(coreLt);

    // Background stars
    const N=3000; const bgG=new THREE.BufferGeometry(); const bgV=new Float32Array(N*3),bgC2=new Float32Array(N*3);
    for(let i=0;i<N;i++){const th=Math.random()*Math.PI*2,ph=Math.acos(2*Math.random()-1),r2=35+Math.random()*55;bgV[i*3]=r2*Math.sin(ph)*Math.cos(th);bgV[i*3+1]=r2*Math.sin(ph)*Math.sin(th);bgV[i*3+2]=r2*Math.cos(ph);const c2=new THREE.Color().setHSL(.55+Math.random()*.35,.5,.4+Math.random()*.6);bgC2[i*3]=c2.r;bgC2[i*3+1]=c2.g;bgC2[i*3+2]=c2.b;}
    bgG.setAttribute('position',new THREE.BufferAttribute(bgV,3));bgG.setAttribute('color',new THREE.BufferAttribute(bgC2,3));
    const bgS=new THREE.Points(bgG,new THREE.PointsMaterial({size:.06,vertexColors:true,blending:THREE.AdditiveBlending,depthWrite:false}));scene.add(bgS);

    // Core
    const coreM=new THREE.Mesh(new THREE.SphereGeometry(.3,32,32),new THREE.MeshBasicMaterial({color:pal.core}));scene.add(coreM);
    const coreG=new THREE.Mesh(new THREE.SphereGeometry(.7,32,32),new THREE.ShaderMaterial({uniforms:{uC:{value:new THREE.Color(pal.core)}},vertexShader:'varying vec3 vN;void main(){vN=normalize(normalMatrix*normal);gl_Position=projectionMatrix*modelViewMatrix*vec4(position,1.0);}',fragmentShader:'varying vec3 vN;uniform vec3 uC;void main(){float i=pow(.65-dot(vN,vec3(0,0,1)),3.5);gl_FragColor=vec4(uC,i*.5);}',transparent:true,blending:THREE.AdditiveBlending,depthWrite:false}));scene.add(coreG);

    // Nebulae
    const nebs=[];
    for(let i=0;i<6;i++){const g=new THREE.PlaneGeometry(15+Math.random()*25,15+Math.random()*25);const m=new THREE.ShaderMaterial({uniforms:{uT:{value:0},uC1:{value:new THREE.Color(pal.nebula[0])},uC2:{value:new THREE.Color(pal.nebula[1])}},vertexShader:'varying vec2 vU;void main(){vU=uv;gl_Position=projectionMatrix*modelViewMatrix*vec4(position,1.0);}',fragmentShader:'varying vec2 vU;uniform float uT;uniform vec3 uC1,uC2;float n(vec2 p){return fract(sin(dot(p,vec2(12.9898,78.233)))*43758.5453);}void main(){float d=length(vU-.5)*2.;float a=smoothstep(1.,.15,d)*.06*(.5+.5*n(vU*8.+uT*.005));gl_FragColor=vec4(mix(uC1,uC2,n(vU*3.)),a);}',transparent:true,blending:THREE.AdditiveBlending,depthWrite:false});const p=new THREE.Mesh(g,m);p.position.set((Math.random()-.5)*25,(Math.random()-.5)*25,(Math.random()-.5)*25);p.rotation.set(Math.random()*Math.PI,Math.random()*Math.PI,Math.random()*Math.PI);scene.add(p);nebs.push(p);}

    // Glow texture
    function gTex(hex){const c=document.createElement('canvas');c.width=128;c.height=128;const x=c.getContext('2d');const g=x.createRadialGradient(64,64,0,64,64,64);g.addColorStop(0,'white');g.addColorStop(.06,hex);g.addColorStop(.25,hex);g.addColorStop(.6,'transparent');x.fillStyle=g;x.fillRect(0,0,128,128);return new THREE.CanvasTexture(c);}

    // Article dots
    const dotG=new THREE.Group();const dots=[];const p3=[];const dCols=[0x22d3ee,0xf472b6,0x34d399,0xfbbf24,0xa78bfa,0xfb923c,0x60a5fa,0xf87171];
    gNodes.forEach((n,i)=>{const col=dCols[i%dCols.length];const hex='#'+new THREE.Color(col).getHexString();const s=new THREE.Sprite(new THREE.SpriteMaterial({map:gTex(hex),color:col,blending:THREE.AdditiveBlending,depthWrite:false,depthTest:true,transparent:true,opacity:.85}));const b=.25+Math.random()*.2;s.userData={node:n,index:i,base:b};s.scale.setScalar(b);const phi=Math.acos(1-2*(i+.5)/gNodes.length),theta=Math.PI*(1+Math.sqrt(5))*i,r=sets.dense;s.position.set(r*Math.sin(phi)*Math.cos(theta),r*Math.sin(phi)*Math.sin(theta),r*Math.cos(phi));p3.push(s.position.clone());dotG.add(s);dots.push(s);});scene.add(dotG);

    // Links
    const lnkG=new THREE.Group();const lnks=[];
    gLinks.forEach(l=>{const si=gNodes.findIndex(n=>n.id===l.source),ti=gNodes.findIndex(n=>n.id===l.target);if(si===-1||ti===-1)return;const mid=new THREE.Vector3((p3[si].x+p3[ti].x)/2,(p3[si].y+p3[ti].y)/2,(p3[si].z+p3[ti].z)/2);const cv=new THREE.QuadraticBezierCurve3(p3[si].clone(),mid,p3[ti].clone());const ln=new THREE.Line(new THREE.BufferGeometry().setFromPoints(cv.getPoints(30)),new THREE.LineBasicMaterial({color:0x1a3050,transparent:true,opacity:.2,blending:THREE.AdditiveBlending,depthWrite:false}));ln.userData={si,ti};lnkG.add(ln);lnks.push(ln);});scene.add(lnkG);

    // Interaction
    const rc=new THREE.Raycaster();const ms=new THREE.Vector2();let hov=null,sel=null;
    const lbl=document.getElementById('star-lbl'),pvC=document.getElementById('pv-card');
    function shPv(n){if(!n){pvC.style.opacity='0';pvC.style.transform='translateX(20px)';pvC.style.pointerEvents='none';lbl.style.opacity='0';return}const s2=n.url.split('/').filter(Boolean).pop()||'',pv=cP[s2],inc=gLinks.filter(l2=>l2.target===n.id).length,out=n.links?.length||0;document.getElementById('pv-t').textContent=n.title;document.getElementById('pv-d').textContent=pv?.desc||'深空中的一颗恒星...';document.getElementById('pv-g').innerHTML=(n.tags||[]).map(t2=>'<span style="padding:.15rem .5rem;border-radius:1rem;font-size:.7rem;background:rgba(255,255,255,.06);color:#94a3b8">#'+t2+'</span>').join('');document.getElementById('pv-o').innerHTML='⬆ '+out+' 出链';document.getElementById('pv-i').innerHTML='⬇ '+inc+' 入链';document.getElementById('pv-go').href=n.url;pvC.style.opacity='1';pvC.style.transform='translateX(0)';pvC.style.pointerEvents='auto';lbl.textContent='✦ '+n.title;lbl.style.opacity='1';}

    cvs.addEventListener('mousemove',e=>{ms.x=(e.clientX/window.innerWidth)*2-1;ms.y=-(e.clientY/window.innerHeight)*2+1;rc.setFromCamera(ms,cam);const h=rc.intersectObjects(dots,false);if(h.length>0){const o=h[0].object;if(hov!==o){if(hov&&hov!==sel)hov.scale.setScalar(hov.userData.base);hov=o;hov.scale.setScalar(hov.userData.base*3.5);shPv(hov.userData.node);document.body.style.cursor='pointer'}}else{if(hov&&hov!==sel)hov.scale.setScalar(hov.userData.base);hov=null;if(!sel)shPv(null);document.body.style.cursor='default'}});
    cvs.addEventListener('click',e=>{if(hov?.userData?.node){if(sel&&sel!==hov)sel.scale.setScalar(sel.userData.base);sel=hov;sel.scale.setScalar(sel.userData.base*5);if(e.detail===2)window.location.href=sel.userData.node.url}else{if(sel){sel.scale.setScalar(sel.userData.base);sel=null;shPv(null)}}});

    // Settings
    document.getElementById('btn-set').addEventListener('click',()=>{const pn=document.getElementById('set-pn');pn.style.display=pn.style.display==='block'?'none':'block'});
    document.getElementById('s-bright').addEventListener('input',function(){sets.bright=+this.value;renderer.toneMappingExposure=sets.bright});
    document.getElementById('s-dense').addEventListener('input',function(){sets.dense=+this.value;dots.forEach((d,i)=>{const phi=Math.acos(1-2*(i+.5)/gNodes.length),theta=Math.PI*(1+Math.sqrt(5))*i,r=sets.dense;d.position.set(r*Math.sin(phi)*Math.cos(theta),r*Math.sin(phi)*Math.sin(theta),r*Math.cos(phi))})});
    document.getElementById('s-spin').addEventListener('input',function(){sets.spin=+this.value;ctrl.autoRotateSpeed=sets.spin});
    document.getElementById('s-theme').addEventListener('change',function(){sets.theme=this.value;pal=pals[sets.theme];scene.fog=new THREE.FogExp2(pal.fog,6e-5);scene.background=new THREE.Color(pal.fog);coreLt.color.set(pal.core);coreM.material.color.set(pal.core);coreG.material.uniforms.uC.value.set(pal.core);nebs.forEach(n2=>{n2.material.uniforms.uC1.value.set(pal.nebula[0]);n2.material.uniforms.uC2.value.set(pal.nebula[1])})});

    function rs(){renderer.setSize(window.innerWidth,window.innerHeight);cam.aspect=window.innerWidth/Math.max(window.innerHeight,1);cam.updateProjectionMatrix()}
    window.addEventListener('resize',rs);rs();

    const clk=new THREE.Clock();
    (function anim(){requestAnimationFrame(anim);const dt=clk.getDelta(),t=performance.now()*.001;ctrl.update();coreM.scale.setScalar(1+Math.sin(t*2.5)*.15);coreLt.intensity=100+Math.sin(t*2.5)*20;bgS.rotation.y+=dt*.015;bgS.rotation.x+=dt*.004;nebs.forEach((n,i)=>{n.material.uniforms.uT.value=t;n.rotation.z+=dt*(.02+i*.008);n.rotation.x+=dt*(.01+i*.006)});dots.forEach((d,i)=>{if(d!==hov&&d!==sel)d.scale.setScalar(d.userData.base*(1+Math.sin(t*3+i*.7)*.15))});lnks.forEach(l=>{const rel=hov&&(l.userData.si===hov.userData.index||l.userData.ti===hov.userData.index);l.material.opacity+=(rel?.6:.2-l.material.opacity)*.08;if(rel)l.material.color.set(0x44aaff)});renderer.render(scene,cam)})();
  })();
</script>

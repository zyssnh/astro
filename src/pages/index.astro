---
import BaseLayout from "../layouts/BaseLayout.astro";
import Greeting from "../components/Greeting";

const base = import.meta.env.BASE_URL;
---

<BaseLayout pageTitle="首页">
  <div class="max-w-3xl mx-auto px-6 py-12 sm:py-16">
  <!-- Hero -->
  <section class="relative overflow-hidden rounded-2xl mb-16 py-16 sm:py-24 px-6 text-center
    light:bg-white light:border light:border-gray-200
    dark:bg-[#131b33]/60 dark:border dark:border-[#1e2d50]">

    <!-- Blur blobs -->
    <div class="absolute inset-0 pointer-events-none overflow-hidden">
      <div class="absolute -top-20 -left-20 w-80 h-80 rounded-full blur-3xl opacity-20 light:bg-blue-400 dark:bg-blue-600"></div>
      <div class="absolute -bottom-20 -right-20 w-96 h-96 rounded-full blur-3xl opacity-15 light:bg-purple-400 dark:bg-purple-700"></div>
    </div>

    <div class="relative z-10 max-w-3xl mx-auto">
      <!-- Math-inspired decoration -->
      <div class="mb-6 inline-flex items-center gap-1.5 text-xs font-mono tracking-wider uppercase
        light:text-blue-600/60 dark:text-blue-400/50">
        <span>&sum;</span> <span>&int;</span> <span>&part;</span> <span class="mx-1">·</span> <span>&infin;</span> <span>&nabla;</span> <span>&prod;</span>
      </div>

      <h1 class="text-3xl sm:text-5xl font-extrabold mb-5 leading-tight tracking-tight
        light:text-[#1a1d23] dark:text-[#e4e8f1]">
        探索<span class="light:text-blue-600 dark:text-blue-400">思维</span>的边界
      </h1>
      <p class="text-base sm:text-lg mb-8 max-w-xl mx-auto leading-relaxed
        light:text-[#5a5f6b] dark:text-[#a0a9ba]">
        一个基于 Astro 构建的技术博客。关注计算机科学、数学与人工智能，
        在整洁的排版中记录思考。
      </p>

      <div class="flex flex-wrap gap-3 justify-center">
        <a href={`${base}/blog/`}
          class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg font-medium text-sm transition-all duration-200
            light:bg-blue-600 light:text-white light:hover:bg-blue-700 light:shadow-sm
            dark:bg-blue-600 dark:text-white dark:hover:bg-blue-500">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"></path></svg>
          阅读文章
        </a>
        <a href={`${base}/graph/`}
          class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg font-medium text-sm transition-all duration-200
            light:bg-gray-100 light:text-gray-700 light:hover:bg-gray-200
            dark:bg-white/8 dark:text-[#a0a9ba] dark:hover:bg-white/15">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"></path><line x1="7" y1="7" x2="7.01" y2="7"></line></svg>
          探索双链
        </a>
      </div>
    </div>
  </section>

  <!-- Welcome -->
  <div class="mb-14 text-center">
    <Greeting client:load messages={[
      "学习 Astro 很有趣",
      "Astro is awesome!",
      "Astro 很棒",
      "欢迎来到我的博客",
      "享受阅读的乐趣"
    ]} />
  </div>

  <!-- Quick nav cards -->
  <section class="mb-16">
    <h2 class="text-xl sm:text-2xl font-bold mb-6 px-1 light:text-[#1a1d23] dark:text-[#e4e8f1]">站点导览</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 stagger-children">
      <a href={`${base}/blog/`} class="card-surface group flex items-start gap-4 p-5 no-underline">
        <div class="w-10 h-10 rounded-lg flex items-center justify-center shrink-0
          light:bg-blue-50 light:text-blue-600 dark:bg-blue-900/20 dark:text-blue-400">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"></path></svg>
        </div>
        <div>
          <h3 class="font-semibold text-sm mb-1 light:text-[#1a1d23] dark:text-[#e4e8f1]">文档</h3>
          <p class="text-xs light:text-[#8b909c] dark:text-[#6b7394]">文章、笔记与归档，按项目分类</p>
        </div>
      </a>

      <a href={`${base}/graph/`} class="card-surface group flex items-start gap-4 p-5 no-underline">
        <div class="w-10 h-10 rounded-lg flex items-center justify-center shrink-0
          light:bg-emerald-50 light:text-emerald-600 dark:bg-emerald-900/20 dark:text-emerald-400">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"></path><line x1="7" y1="7" x2="7.01" y2="7"></line></svg>
        </div>
        <div>
          <h3 class="font-semibold text-sm mb-1 light:text-[#1a1d23] dark:text-[#e4e8f1]">双链</h3>
          <p class="text-xs light:text-[#8b909c] dark:text-[#6b7394]">3D 宇宙中探索文章间的联系</p>
        </div>
      </a>
    </div>
  </section>
  </div>
</BaseLayout>

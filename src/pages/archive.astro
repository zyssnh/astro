---
import BaseLayout from "../layouts/BaseLayout.astro";

const base = import.meta.env.BASE_URL;

const allPosts = Object.values(
    import.meta.glob("./posts/*.md", { eager: true }),
).sort((a: any, b: any) => {
    return new Date(b.frontmatter.pubDate).getTime() - new Date(a.frontmatter.pubDate).getTime();
});

// Group posts by year
const byYear: Record<string, any[]> = {};
allPosts.forEach((post: any) => {
    const year = new Date(post.frontmatter.pubDate).getFullYear().toString();
    if (!byYear[year]) byYear[year] = [];
    byYear[year].push(post);
});
const years = Object.keys(byYear).sort((a, b) => Number(b) - Number(a));

// Collect all tags with post counts
const tagCounts: Record<string, number> = {};
allPosts.forEach((post: any) => {
    (post.frontmatter.tags || []).forEach((tag: string) => {
        tagCounts[tag] = (tagCounts[tag] || 0) + 1;
    });
});
const allTags = Object.entries(tagCounts).sort((a, b) => b[1] - a[1]);

const formatDate = (date: string) => {
    if (!date) return '';
    const d = new Date(date);
    return d.toLocaleDateString('zh-CN', { month: '2-digit', day: '2-digit' });
};
---

<BaseLayout pageTitle="归档">
    <div class="max-w-3xl mx-auto">
        <h1 class="text-3xl font-extrabold mb-2 light:text-[#1a1d23] dark:text-[#e4e8f1]">归档</h1>
        <p class="text-sm mb-8 light:text-[#8b909c] dark:text-[#6b7394]">
            共 {allPosts.length} 篇文章，{years.length} 个年份
        </p>

        <!-- Tag index -->
        <div class="mb-10 pb-8 border-b light:border-gray-200 dark:border-[#1e2d50]">
            <h2 class="text-xs font-semibold uppercase tracking-wider mb-3 light:text-[#8b909c] dark:text-[#6b7394]">
                标签索引
            </h2>
            <div class="flex flex-wrap gap-2">
                {allTags.map(([tag, count]) => (
                    <a href={`${base}/tags/${tag}`}
                        class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-sm font-medium border transition-all
                            light:bg-white light:text-[#5a5f6b] light:border-gray-200 light:hover:border-blue-300 light:hover:text-blue-600
                            dark:bg-white/5 dark:text-[#a0a9ba] dark:border-[#1e2d50] dark:hover:border-blue-700 dark:hover:text-blue-400">
                        {tag}
                        <span class="text-xs opacity-50">{count}</span>
                    </a>
                ))}
            </div>
        </div>

        <!-- Timeline by year -->
        {years.map((year) => (
            <div class="mb-10">
                <h2 class="text-xl font-bold mb-4 flex items-center gap-3
                    light:text-[#1a1d23] dark:text-[#e4e8f1]">
                    {year}
                    <span class="text-xs font-normal px-2 py-0.5 rounded-full
                        light:bg-gray-100 light:text-[#8b909c]
                        dark:bg-white/5 dark:text-[#6b7394]">
                        {byYear[year].length}
                    </span>
                </h2>

                <div class="space-y-1">
                    {byYear[year].map((post: any) => (
                        <a href={post.url}
                            class="flex items-baseline gap-4 py-2 px-3 -mx-3 rounded-lg group transition-colors
                                light:hover:bg-gray-50 dark:hover:bg-white/5">
                            <time class="text-xs font-mono shrink-0 w-14 light:text-[#8b909c] dark:text-[#6b7394]
                                group-hover:light:text-blue-600 group-hover:dark:text-blue-400 transition-colors">
                                {formatDate(post.frontmatter.pubDate)}
                            </time>
                            <span class="text-sm font-medium truncate
                                light:text-[#1a1d23] group-hover:light:text-blue-600
                                dark:text-[#e4e8f1] dark:group-hover:text-blue-400
                                transition-colors">
                                {post.frontmatter.title}
                            </span>
                            {post.frontmatter.tags && post.frontmatter.tags.length > 0 && (
                                <span class="hidden sm:flex gap-1 ml-auto shrink-0">
                                    {post.frontmatter.tags.slice(0, 3).map((tag: string) => (
                                        <span class="px-1.5 py-0.5 rounded text-xs
                                            light:bg-gray-100 light:text-[#8b909c]
                                            dark:bg-white/5 dark:text-[#6b7394]">
                                            {tag}
                                        </span>
                                    ))}
                                </span>
                            )}
                        </a>
                    ))}
                </div>
            </div>
        ))}
    </div>
</BaseLayout>

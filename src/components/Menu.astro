---
const base = import.meta.env.BASE_URL;
---

<div class="relative">
    <button
        id="menu-button"
        type="button"
        class="inline-flex items-center justify-center rounded-lg p-2.5 transition-colors
          light:text-gray-600 light:hover:bg-gray-100
          dark:text-gray-300 dark:hover:bg-white/10
          focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500"
        aria-expanded="false"
        aria-controls="menu-panel"
        aria-label="打开菜单"
    >
        <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
    </button>

    <nav
        id="menu-panel"
        class="hidden absolute left-0 mt-3 w-52 rounded-xl shadow-xl border z-50
          light:bg-white light:border-gray-200
          dark:bg-[#131b33] dark:border-[#1e2d50]"
    >
        <ul class="flex flex-col p-2 gap-0.5 text-sm">
            <li><a href={`${base}/`} class="menu-link">首页</a></li>
            <li><a href={`${base}/blog/`} class="menu-link">博客</a></li>
            <li><a href={`${base}/archive/`} class="menu-link">归档</a></li>
            <li><a href={`${base}/collect/`} class="menu-link">收藏</a></li>
            <li><a href={`${base}/tags/`} class="menu-link">标签</a></li>
            <li><a href={`${base}/graph/`} class="menu-link neon-cyan">双链</a></li>
        </ul>
    </nav>
</div>

<style>
  .menu-link {
    display: block;
    padding: 0.55rem 0.9rem;
    border-radius: 0.5rem;
    text-decoration: none;
    font-weight: 500;
    transition: all 0.15s ease;
  }
  html.light .menu-link { color: #4b5563; }
  html.light .menu-link:hover { color: #2563eb; background-color: #eff6ff; }
  html.dark .menu-link { color: #a0a9ba; }
  html.dark .menu-link:hover { color: #60a5fa; background-color: rgba(59,130,246,0.1); }
</style>

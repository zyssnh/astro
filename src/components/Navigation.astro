---
const base = import.meta.env.BASE_URL;
---

<nav id="main-menu" class="flex gap-1 items-center justify-center">
    <a href={`${base}/`} class="nav-link">首页</a>
    <a href={`${base}/blog/`} class="nav-link">博客</a>
    <a href={`${base}/archive/`} class="nav-link">归档</a>
    <a href={`${base}/collect/`} class="nav-link">收藏</a>
    <a href={`${base}/tags/`} class="nav-link">标签</a>
</nav>

<style>
  .nav-link {
    padding: 0.4rem 0.85rem;
    border-radius: 0.5rem;
    font-size: 0.9rem;
    font-weight: 500;
    text-decoration: none;
    transition: all 0.2s ease;
  }
  html.light .nav-link { color: #4b5563; }
  html.light .nav-link:hover { color: #2563eb; background-color: #eff6ff; }
  html.dark .nav-link { color: #a0a9ba; }
  html.dark .nav-link:hover { color: #60a5fa; background-color: rgba(59,130,246,0.1); }
</style>

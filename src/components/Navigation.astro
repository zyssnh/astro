---
const base = import.meta.env.BASE_URL;
---

<nav id="main-menu" class="flex gap-0.5 items-center justify-center">
    <a href={`${base}/`} class="nav-link">首页</a>
    <a href={`${base}/blog/`} class="nav-link">文档</a>
    <a href={`${base}/graph/`} class="nav-link">双链</a>
</nav>

<style>
  .nav-link {
    padding: 0.3rem 0.75rem;
    border-radius: 0.375rem;
    font-size: 0.875rem;
    font-weight: 450;
    text-decoration: none;
    transition: all 0.2s ease;
  }
  html.light .nav-link { color: #6b7280; }
  html.light .nav-link:hover { color: #111827; background-color: #f3f4f6; }
  html.dark .nav-link { color: #94a3b8; }
  html.dark .nav-link:hover { color: #e2e8f0; background-color: rgba(255,255,255,0.06); }
</style>

---
const { url, title, description, author, pubDate, tags } = Astro.props;

const formatDate = (date: string) => {
  if (!date) return '';
  const d = new Date(date);
  return d.toLocaleDateString('zh-CN', { year: 'numeric', month: '2-digit', day: '2-digit' });
};
---

<article class="card-surface group flex flex-col p-5 cursor-pointer animate-in">
  <div class="flex-1">
    <h3 class="text-lg font-semibold mb-2 leading-snug
      light:text-[#1a1d23] group-hover:text-blue-600
      dark:text-[#e4e8f1] dark:group-hover:text-blue-400
      transition-colors">
      <a href={url} class="no-underline">{title}</a>
    </h3>

    {description && (
      <p class="text-sm mb-4 line-clamp-2 light:text-[#5a5f6b] dark:text-[#a0a9ba]">{description}</p>
    )}
  </div>

  <div class="flex items-center gap-3 text-xs light:text-[#8b909c] dark:text-[#6b7394]">
    {pubDate && (
      <span class="flex items-center gap-1">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
        {formatDate(pubDate)}
      </span>
    )}
    {author && (
      <span class="flex items-center gap-1">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path><circle cx="12" cy="7" r="4"></circle></svg>
        {author}
      </span>
    )}
  </div>

  {tags && tags.length > 0 && (
    <div class="flex flex-wrap gap-1.5 mt-3">
      {tags.map((tag: string) => (
        <span class="px-2 py-0.5 rounded-full text-xs font-medium
          light:bg-blue-50 light:text-blue-600
          dark:bg-blue-900/20 dark:text-blue-300">
          {tag}
        </span>
      ))}
    </div>
  )}
</article>

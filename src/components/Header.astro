---
import Menu from "./Menu.astro";
import ThemeIcon from "./ThemeIcon.astro";
import Navigation from "./Navigation.astro";
---

<header class="sticky top-0 z-50 backdrop-blur-md
  light:bg-white/90 light:border-b light:border-gray-200/60 light:shadow-sm
  dark:bg-blue-950/80 dark:border-b dark:border-purple-800/40 dark:shadow-lg">
  <nav class="max-w-7xl mx-auto px-4 py-3 flex justify-between items-center">
    <!-- 移动端菜单按钮 -->
    <div class="lg:hidden">
      <Menu />
    </div>

    <!-- 桌面端导航 -->
    <div class="hidden lg:flex flex-1 justify-center">
      <Navigation />
    </div>

    <!-- 主题切换 -->
    <div class="ml-auto">
      <ThemeIcon />
    </div>
  </nav>
</header>

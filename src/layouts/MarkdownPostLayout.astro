---
import BaseLayout from "./BaseLayout.astro";
import ArticleHeader from "../components/ArticleHeader.astro";

const { frontmatter } = Astro.props;
---

<BaseLayout pageTitle={frontmatter.title}>
    <ArticleHeader
        title={frontmatter.title}
        description={frontmatter.description}
        author={frontmatter.author}
        pubDate={frontmatter.pubDate}
        tags={frontmatter.tags}
        image={frontmatter.image}
    />

    <div class="flex gap-8 lg:gap-12">
        <!-- Main content: constrained width for readability -->
        <article class="prose light:prose-slate dark:prose-invert max-w-3xl mx-auto flex-1 min-w-0">
            <slot />
        </article>

        <!-- TOC sidebar -->
        <aside class="hidden lg:block w-56 shrink-0" id="toc-sidebar">
            <nav id="toc" class="sticky top-24">
                <h2 class="text-xs font-semibold uppercase tracking-wider mb-3 light:text-[#8b909c] dark:text-[#6b7394]">目录</h2>
                <ul id="toc-list" class="space-y-0.5 text-sm"></ul>
            </nav>
        </aside>
    </div>
</BaseLayout>

<style>
  #toc-list { list-style: none; padding: 0; margin: 0; }

  .toc-item {
    display: block;
    padding: 0.25rem 0.5rem;
    border-radius: 0.375rem;
    transition: all 0.2s ease;
    text-decoration: none;
    border-left: 2px solid transparent;
  }

  html.light .toc-item { color: #8b909c; }
  html.light .toc-item:hover { color: #2563eb; background: #f0f2f5; }
  html.light .toc-item.is-active {
    color: #2563eb;
    background: #eff6ff;
    border-left-color: #3b82f6;
  }

  html.dark .toc-item { color: #6b7394; }
  html.dark .toc-item:hover { color: #93bbfd; background: rgba(255,255,255,0.04); }
  html.dark .toc-item.is-active {
    color: #60a5fa;
    background: rgba(59,130,246,0.1);
    border-left-color: #3b82f6;
  }

  .toc-item.toc-h2 { padding-left: 0.5rem; font-weight: 500; }
  .toc-item.toc-h3 { padding-left: 1.25rem; font-size: 0.85em; }

  /* Mobile: show TOC inline at top */
  @media (max-width: 1023px) {
    #toc-sidebar { display: block !important; width: 100%; }
    #toc { position: static; margin-bottom: 2rem; padding-bottom: 1rem;
      border-bottom: 1px solid var(--color-border, #e5e7eb); }
    #toc-list { display: flex; flex-wrap: wrap; gap: 0.35rem; }
    .toc-item { border-left: none; border-radius: 1rem; font-size: 0.8rem; padding: 0.2rem 0.65rem; }
  }
</style>

<script>
  (function() {
    const tocList = document.getElementById('toc-list');
    const article = document.querySelector('article.prose');
    if (!tocList || !article) return;

    // Collect h2/h3 headings
    const headings = article.querySelectorAll('h2, h3');
    if (headings.length === 0) {
      document.getElementById('toc-sidebar')!.style.display = 'none';
      return;
    }

    const observed: { el: Element; item: Element }[] = [];

    headings.forEach(function(h, i) {
      const id = h.id || 'heading-' + i;
      h.id = id;

      const level = h.tagName.toLowerCase();
      const a = document.createElement('a');
      a.href = '#' + id;
      a.className = 'toc-item ' + (level === 'h2' ? 'toc-h2' : 'toc-h3');
      a.textContent = h.textContent || '';

      const li = document.createElement('li');
      li.appendChild(a);
      tocList.appendChild(li);

      observed.push({ el: h, item: a });
    });

    // IntersectionObserver for scroll highlighting
    const observer = new IntersectionObserver(
      function(entries) {
        entries.forEach(function(entry) {
          const match = observed.find(function(o) { return o.el === entry.target; });
          if (!match) return;
          if (entry.isIntersecting) {
            // Remove active from all
            observed.forEach(function(o) { o.item.classList.remove('is-active'); });
            match.item.classList.add('is-active');
          }
        });
      },
      { rootMargin: '-80px 0px -70% 0px', threshold: 0 }
    );

    headings.forEach(function(h) { observer.observe(h); });
  })();
</script>
